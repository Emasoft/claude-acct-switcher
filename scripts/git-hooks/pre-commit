#!/usr/bin/env bash
# pre-commit: code-review gate with Codex (primary) + Opus agent (fallback).
#
# Runs `codex review --uncommitted -c model_reasoning_effort="high"` on
# staged + unstaged + untracked changes and BLOCKS the commit if the
# reviewer flags any finding at MINOR, MAJOR, or CRITICAL severity.
# NIT findings DO NOT block (surfaced as a count for opportunistic
# pickup).
#
# If Codex returns a non-zero exit code (out of credits / rate-limited /
# network unreachable / internal error / etc.) we fall back to a Claude
# Opus review delivered via a custom subagent at
#   ~/.claude/agents/review-opus-agent.md
# launched with `claude --agent review-opus-agent --dangerously-skip-permissions`.
#
# We deliberately do NOT use `claude -p` for the fallback: per project
# convention `-p` is observed to consume metered Anthropic API tokens
# instead of the OAuth Pro/Max subscription. The agent + custom-subagent
# path uses the subscription path.
#
# We also do NOT use `--worktree`: empirically `git worktree add` fails
# inside a pre-commit hook with
#   fatal: .git/index: index file open failed: Not a directory
# because the parent `git commit` holds the index. The agent runs in
# the main checkout cwd instead. Sandbox-equivalent safety comes from
# the agent's tool list (`Read, Write, Bash, Glob, Grep` — NO Edit) and
# its review-only instructions: it MUST only Write to REPORT_PATH and
# MUST NOT use Bash for any state-mutating command on source files.
#
# Why -c instead of --effort: the codex `review` subcommand does NOT
# accept --effort (only `task` does). The TOML config override is the
# one-invocation-scoped equivalent. Default in ~/.codex/config.toml is
# "xhigh"; we drop to "high" so the gate finishes in minutes instead
# of half-hours.
#
# Bypass for emergencies (use sparingly):
#   git commit --no-verify
#
# Source of truth: scripts/git-hooks/pre-commit (git-tracked).
# Active copy:     .git/hooks/pre-commit (per-clone, install via
#                  scripts/install-precommit-hook.sh).

# `set -e` would abort on bare `grep -q` returning non-zero (a legitimate
# "no findings" signal), so use -u and pipefail without -e.
set -uo pipefail

# Tunables — override via env if needed.
CODEX_TIMEOUT_SEC="${CODEX_TIMEOUT_SEC:-1800}"   # 30 min cap on codex review
OPUS_TIMEOUT_SEC="${OPUS_TIMEOUT_SEC:-1800}"     # 30 min cap on opus fallback

# ── Skip when there is genuinely nothing to review ────────────────────
HAS_STAGED=1; git diff --cached --quiet 2>/dev/null && HAS_STAGED=0
HAS_UNSTAGED=1; git diff --quiet 2>/dev/null && HAS_UNSTAGED=0
HAS_UNTRACKED=0; [[ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ]] && HAS_UNTRACKED=1
if [[ "$HAS_STAGED" -eq 0 && "$HAS_UNSTAGED" -eq 0 && "$HAS_UNTRACKED" -eq 0 ]]; then
  echo "[pre-commit] Nothing to review — skipping." >&2
  exit 0
fi

# ── Bookkeeping: report path ─────────────────────────────────────────
# Three-tier resolution (most → least specific):
#  1. PRECOMMIT_REPORTS_DIR env var (caller can pin a path explicitly)
#  2. $ROOT/reports/codex-review/pre-commit/ IF /reports/ is gitignored
#     in this repo (vdm-style: keeps reports next to the code while
#     guaranteeing they never land in commits)
#  3. ~/.cache/codex-precommit/<repo-basename>/  (safe default for
#     ANY repo — reports live outside the working tree so the hook is
#     drop-in safe for repos that don't have /reports/ in gitignore)
# Reports may contain code excerpts, secret-bearing log lines, and
# absolute paths — leaking them into a tracked file would be a real
# privacy hit, so the default is the global cache.
ROOT="$(git rev-parse --show-toplevel)"
TS="$(date +%Y%m%d_%H%M%S%z)"
if [[ -n "${PRECOMMIT_REPORTS_DIR:-}" ]]; then
  REVIEW_DIR="$PRECOMMIT_REPORTS_DIR"
elif [[ -f "$ROOT/.gitignore" ]] && grep -qE '^/?reports/?$' "$ROOT/.gitignore" 2>/dev/null; then
  REVIEW_DIR="$ROOT/reports/codex-review/pre-commit"
else
  REVIEW_DIR="$HOME/.cache/codex-precommit/$(basename "$ROOT")"
fi
mkdir -p "$REVIEW_DIR"
REPORT="$REVIEW_DIR/${TS}-pre-commit.md"

# ── F-003 fix: detect timeout binary; fall through if unavailable ─────
# GNU coreutils ships `timeout`; macOS Homebrew ships it as `gtimeout`.
# On a clean macOS without coreutils, neither exists — we keep going
# without a timeout rather than fail every commit.
if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_BIN="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_BIN="gtimeout"
else
  TIMEOUT_BIN=""
fi

run_with_timeout() {
  local secs="$1"; shift
  if [[ -n "$TIMEOUT_BIN" ]]; then
    "$TIMEOUT_BIN" --kill-after=30 "$secs" "$@"
  else
    "$@"
  fi
}

# ── Severity-row regex shared by both branches ────────────────────────
# Codex emits a markdown findings table with rows of the shape:
#   | <code> | <SEVERITY> | <file:line> | <summary> |
# The Opus agent prompt (~/.claude/agents/review-opus-agent.md) instructs
# Opus to emit the SAME shape so the downstream grep works identically
# for both reviewers.
BLOCKING_REGEX='^\|[^|]+\|[[:space:]]*(CRITICAL|MAJOR|MINOR)[[:space:]]*\|'
NIT_REGEX='^\|[^|]+\|[[:space:]]*NIT[[:space:]]*\|'

# (No worktree cleanup helper — see header note: --worktree dropped
# because it can't be created from a pre-commit hook.)

# ── Helper: run the Opus fallback review via the subagent ─────────────
# Stages the diff + untracked file list under /tmp, launches the
# `review-opus-agent` subagent in the main checkout cwd (NOT a worktree
# — see header note: --worktree fails inside a pre-commit hook), and
# waits for the agent to write the report at REPORT_PATH (passed in $1).
# Returns the claude CLI exit code.
run_opus_fallback() {
  local report_path="$1"

  if ! command -v claude >/dev/null 2>&1; then
    echo "[pre-commit] Opus fallback unavailable: claude CLI not on PATH." >&2
    return 127
  fi

  # ── F-002 fix: include untracked file CONTENTS, not just the list.
  # Stage the diff and untracked-list under /tmp; the agent will
  # absolute-path-read each untracked file from MAIN_ROOT itself (with
  # binary / size / cache-dir guards in the agent prompt). /tmp avoids
  # polluting the repo with .precommit-staging/ residue.
  local stage_dir
  stage_dir="$(mktemp -d "${TMPDIR:-/tmp}/precommit-agent-XXXXXX")"
  trap "rm -rf -- '$stage_dir'" RETURN
  local diff_file="$stage_dir/diff.patch"
  local untracked_file="$stage_dir/untracked.txt"
  git -C "$ROOT" diff HEAD > "$diff_file" 2>/dev/null || true
  git -C "$ROOT" ls-files --others --exclude-standard > "$untracked_file" 2>/dev/null || true

  # Ensure the report's parent directory exists BEFORE the agent runs
  # (so the agent's Write tool can land cleanly).
  mkdir -p "$(dirname "$report_path")"

  # Build the orchestrator prompt that hands the agent its inputs.
  local prompt
  prompt="Run the pre-commit code review now. Inputs (absolute paths):

- DIFF_PATH:      $diff_file
- UNTRACKED_LIST: $untracked_file
- MAIN_ROOT:      $ROOT
- REPORT_PATH:    $report_path

Begin immediately. After writing the report, finish your turn — do not wait for further instructions."

  # ── F-004 fix: pipe prompt via stdin instead of as argv. macOS
  # ARG_MAX can be exceeded for large diffs (we already bound the
  # prompt small here, but stdin is the safer pattern that scales).
  # NOT using -p: we want the OAuth subscription, not metered API tokens.
  # NOT using --worktree: see header note (fails in pre-commit context).
  printf '%s' "$prompt" | run_with_timeout "${OPUS_TIMEOUT_SEC}" \
    claude --agent review-opus-agent --dangerously-skip-permissions \
      2>&1 | tee "${report_path}.run.log" >&2
  local rc=${PIPESTATUS[1]}

  # The agent MAY have failed silently (no report written) even with rc=0
  # if claude itself bailed before the agent's first turn completed.
  # Hard-require a non-empty report file as the success signal.
  if [[ ! -s "$report_path" ]]; then
    echo "[pre-commit] Opus fallback: agent did not write report at $report_path" >&2
    return ${rc:-1}
  fi
  return "$rc"
}

# ── Primary attempt: Codex ────────────────────────────────────────────
USED_FALLBACK=0
RC=127

if ! command -v codex >/dev/null 2>&1; then
  echo "[pre-commit] codex CLI not on PATH — falling back to Opus..." >&2
  USED_FALLBACK=1
else
  echo "[pre-commit] Reviewing uncommitted changes via Codex (this can take several minutes)..." >&2
  echo "             Effort: high  (-c model_reasoning_effort=\"high\", default xhigh)" >&2
  echo "             Report: $REPORT" >&2
  echo >&2
  run_with_timeout "${CODEX_TIMEOUT_SEC}" \
    codex review --uncommitted -c model_reasoning_effort="high" 2>&1 | tee "$REPORT" >&2
  RC=${PIPESTATUS[0]}
  if [[ "$RC" -ne 0 ]]; then
    REASON=$(grep -m1 -E 'ERROR:|usage limit|rate limit|unreachable|timed out|Review was interrupted' "$REPORT" 2>/dev/null \
             | head -c 240 || true)
    echo >&2
    echo "[pre-commit] Codex unavailable (rc=$RC). Falling back to Opus." >&2
    [[ -n "$REASON" ]] && echo "             Codex said: $REASON" >&2
    USED_FALLBACK=1
  fi
fi

# ── Fallback: Opus subagent ───────────────────────────────────────────
if [[ "$USED_FALLBACK" -eq 1 ]]; then
  # Opus report goes under reports/review-opus-agent/ (NOT codex-review/)
  # to make the source of the verdict obvious to anyone reading the
  # archive later. Mirrors the three-tier resolution from the codex
  # report path above (env override → repo-local-if-gitignored → global
  # cache) so the same safety guarantees apply.
  if [[ -n "${PRECOMMIT_OPUS_REPORTS_DIR:-}" ]]; then
    OPUS_REPORT_DIR="$PRECOMMIT_OPUS_REPORTS_DIR"
  elif [[ -f "$ROOT/.gitignore" ]] && grep -qE '^/?reports/?$' "$ROOT/.gitignore" 2>/dev/null; then
    OPUS_REPORT_DIR="$ROOT/reports/review-opus-agent"
  else
    OPUS_REPORT_DIR="$HOME/.cache/codex-precommit/$(basename "$ROOT")/review-opus-agent"
  fi
  mkdir -p "$OPUS_REPORT_DIR"
  OPUS_REPORT="$OPUS_REPORT_DIR/${TS}-pre-commit.md"
  echo "[pre-commit] Reviewing uncommitted changes via Claude Opus (--agent review-opus-agent)..." >&2
  echo "             Report path: $OPUS_REPORT" >&2
  echo >&2
  # ── F-001 fix: capture rc OUTSIDE the `if !` so $? reflects the
  # function's actual exit, not the inverted test. Pre-fix the rc was
  # always 0 because the `!` consumed the status before the `then`.
  run_opus_fallback "$OPUS_REPORT"
  OPUS_RC=$?
  if [[ "$OPUS_RC" -ne 0 ]]; then
    echo >&2
    echo "[pre-commit] BOTH reviewers failed (codex rc=$RC, opus rc=$OPUS_RC)." >&2
    echo "             Inspect: $REPORT" >&2
    echo "             Inspect: ${OPUS_REPORT}.run.log (claude transcript)" >&2
    [[ -s "$OPUS_REPORT" ]] && echo "             Inspect: $OPUS_REPORT" >&2
    echo "             Bypass with: git commit --no-verify" >&2
    exit 1
  fi
  REPORT="$OPUS_REPORT"
fi

# ── Parse findings ────────────────────────────────────────────────────
# Block on any CRITICAL / MAJOR / MINOR row. NIT rows pass.
if grep -qE "$BLOCKING_REGEX" "$REPORT"; then
  echo >&2
  echo "[pre-commit] BLOCKED — reviewer found MINOR or above issue(s):" >&2
  echo >&2
  grep -E "$BLOCKING_REGEX" "$REPORT" | sed 's/^/    /' >&2
  echo >&2
  echo "[pre-commit] Full report: $REPORT" >&2
  echo "[pre-commit] Bypass with: git commit --no-verify" >&2
  exit 1
fi

# Pass — surface NIT count for context but do not block.
# `grep -c` exits 1 with stdout "0" when there are zero matches; pairing
# that with `|| echo 0` produces a two-line "0\n0" string and trips the
# arithmetic test below. awk's `n+0` always prints a single integer.
NIT_COUNT=$(awk -v re="$NIT_REGEX" '$0 ~ re {n++} END {print n+0}' "$REPORT" 2>/dev/null || echo 0)
if [[ "$NIT_COUNT" -gt 0 ]]; then
  echo "[pre-commit] PASS — no MINOR or above. ($NIT_COUNT NIT finding(s) in $REPORT)" >&2
else
  echo "[pre-commit] PASS — no findings." >&2
fi
exit 0
