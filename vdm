# ─────────────────────────────────────────────────────────
# Main dispatch
# ─────────────────────────────────────────────────────────

# Idempotent: migrate any plaintext accounts/<name>.json files into
# vdm-account-* keychain entries before any command runs. Safe to
# call on every invocation — entries already in the keychain are not
# rewritten, files that fail to migrate are left in place for retry.
migrate_accounts_to_keychain 2>/dev/null || true

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  add)       cmd_add "$@" ;;
  label)     cmd_label "$@" ;;
  list|ls)   cmd_list ;;
  switch|sw) cmd_switch "$@" ;;
  remove|rm) cmd_remove "$@" ;;
  status|st) cmd_status ;;
  config|cfg) cmd_config "$@" ;;
  dashboard) cmd_dashboard "$@" ;;
  logs|log) cmd_logs "$@" ;;
  tokens|tok) cmd_tokens "$@" ;;
  upgrade|update) cmd_upgrade ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $command${NC}"
    cmd_help
    exit 1
    ;;
esac
