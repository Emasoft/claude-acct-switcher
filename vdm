#!/usr/bin/env bash
# vdm - Van Damme-o-Matic
# Manages multiple Claude Code OAuth credential profiles via macOS Keychain.
# All running Claude Code sessions share the same Keychain entry,
# so switching here affects every open tab.

set -euo pipefail

# Resolve SCRIPT_DIR canonically, BSD-portable.
# Stock macOS lacks GNU `readlink -f` and `realpath`; the previous chain
# silently fell back to `echo "$0"` which left the path uncanonicalised
# whenever vdm was invoked through a symlink. We instead walk the symlink
# chain manually with plain `readlink` (POSIX), then `cd … && pwd -P`.
_vdm_resolve_script_path() {
  local p="$1"
  local target
  while [[ -L "$p" ]]; do
    target="$(readlink "$p")"
    if [[ "$target" = /* ]]; then
      p="$target"
    else
      p="$(dirname "$p")/$target"
    fi
  done
  printf '%s' "$p"
}
SCRIPT_DIR="$(cd "$(dirname "$(_vdm_resolve_script_path "$0")")" && pwd -P)"
ACCOUNTS_DIR="$SCRIPT_DIR/accounts"
KEYCHAIN_ACCOUNT="$(whoami)"
DASHBOARD_PORT="${CSW_PORT:-3333}"
PROXY_PORT="${CSW_PROXY_PORT:-3334}"
DASHBOARD_PID_FILE="$SCRIPT_DIR/.dashboard.pid"
CONFIG_FILE="$SCRIPT_DIR/config.json"
ACTIVITY_LOG_FILE="$SCRIPT_DIR/activity-log.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

mkdir -p "$ACCOUNTS_DIR"

# ─────────────────────────────────────────────────────────
# Startup migration: ensure hooks are installed
# (handles upgrades from versions that didn't ship install-hooks.sh)
# ─────────────────────────────────────────────────────────

if [[ -f "$SCRIPT_DIR/install-hooks.sh" ]]; then
  # Opt-out sentinel: a user who deliberately removed the token-tracking
  # hooks (perhaps because they're noisy or they're testing alternative
  # tracking) can place this file to keep them removed across vdm
  # invocations. Without this, the migration silently re-installed disabled
  # hooks every time any vdm subcommand ran (audit finding 05.C10).
  if [[ -f "$HOME/.claude/account-switcher/.hooks-disabled" ]]; then
    : # respect user's opt-out
  else
    _needs_hooks=false
    if [[ ! -f "$HOME/.claude/settings.json" ]]; then
      _needs_hooks=true
    elif ! grep -q "api/session-start" "$HOME/.claude/settings.json" 2>/dev/null; then
      _needs_hooks=true
    elif ! grep -q "StopFailure" "$HOME/.claude/settings.json" 2>/dev/null; then
      # Existing install predates the StopFailure / SubagentStop / SessionStart
      # additions; trigger a re-install so an upgrade picks them up.
      _needs_hooks=true
    fi
    if [[ "$_needs_hooks" == "true" ]]; then
      source "$SCRIPT_DIR/install-hooks.sh"
      install_hooks 2>/dev/null || true
    fi
    unset _needs_hooks
  fi
fi

# ─────────────────────────────────────────────────────────
# Keychain service auto-detection
# ─────────────────────────────────────────────────────────

detect_keychain_service() {
  # Mirror dashboard.mjs::detectKeychainService byte-for-byte: try the
  # canonical name "Claude Code-credentials" first, then fall back to
  # `security dump-keychain` and pick the first "Claude*" entry. The bash and
  # Node sides MUST agree; otherwise vdm and the dashboard read different
  # keychain entries on the same machine, the active token diverges, and
  # rotation logic loses the ground truth.
  if security find-generic-password -a "$KEYCHAIN_ACCOUNT" -s "Claude Code-credentials" -w &>/dev/null; then
    echo "Claude Code-credentials"
    return
  fi
  # Broader search — same `head -1` as dashboard.mjs (intentionally NOT sorted
  # so both sides return the same arbitrary-but-equal first match). NB: the
  # determinism fix should be applied symmetrically to both sides; tracked as
  # NEEDS_DESIGN in the audit report.
  local svc
  svc=$(security dump-keychain 2>/dev/null \
    | grep -A4 '"svce"' \
    | grep -i claude \
    | sed -n 's/.*"svce"<blob>="\([^"]*\)".*/\1/p' \
    | head -1) || true
  if [[ -n "$svc" ]]; then
    echo "$svc"
    return
  fi
  # Fallback
  echo "Claude Code-credentials"
}

KEYCHAIN_SERVICE="$(detect_keychain_service)"

# ─────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────

# Strict profile-name sanitiser. Profile names land directly in filesystem
# paths (`accounts/<name>.json`, `accounts/<name>.label`) and in shell
# arguments to `rm`, `cp`, `cat`, `>`. The previous one-line tr-only
# normaliser kept characters that are dangerous in those contexts:
#   * `..`, `/` — directory traversal out of accounts/
#   * `*`, `?`, `[` — glob expansion on `rm -f "$ACCOUNTS_DIR/${name}.json"`
#   * backticks, `;`, `$()`, `&` — command substitution if the name is ever
#     re-quoted incorrectly downstream
#   * leading `-` — interpreted as an option flag by some commands
# We collapse to a strict whitelist (alnum, `_`, `.`, `-`) AFTER the
# space-and-case normaliser, then reject the empty string, `.`, `..`, and
# any name starting with `-`.
sanitize_profile_name() {
  local raw="${1:-}"
  local name
  # Step 1 (existing behaviour): spaces → dashes, lowercase.
  name=$(printf '%s' "$raw" | tr ' ' '-' | tr '[:upper:]' '[:lower:]')
  # Step 2: drop everything outside the strict whitelist.
  name=$(printf '%s' "$name" | LC_ALL=C tr -cd '[:alnum:]_.-')
  # Step 3: reject empty / traversal / leading-dash names.
  case "$name" in
    "" | "." | "..") return 1 ;;
    -*)              return 1 ;;
  esac
  printf '%s' "$name"
}

read_keychain() {
  security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null
}

write_keychain() {
  local creds="$1"
  # `-U` updates in place if entry exists; creates otherwise. Atomic single
  # operation — no delete-then-add window where concurrent readers see null.
  security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w "$creds"
}

# ─────────────────────────────────────────────────────────
# Per-account keychain ops (vdm-account-<name>)
#
# Saved-but-inactive accounts live in their own keychain entries instead
# of as plaintext files in $ACCOUNTS_DIR. The service name format is
# `vdm-account-<name>`; the account ($KEYCHAIN_ACCOUNT) is shared with
# the active-credentials slot. Label files (just the email or display
# name) still live as plain files alongside $ACCOUNTS_DIR — they carry
# no secret material.
# ─────────────────────────────────────────────────────────

VDM_ACCOUNT_PREFIX="vdm-account-"

# Validate vdm account name. Stricter than sanitize_profile_name —
# matches the JS-side `vdmAccountServiceName` validator in lib.mjs.
# Returns the name on stdout if valid, exit 1 if not.
validate_vdm_account_name() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then return 1; fi
  if [[ "$name" == "index" ]]; then return 1; fi  # reserved
  if ! [[ "$name" =~ ^[a-zA-Z0-9._@-]+$ ]]; then return 1; fi
  printf '%s' "$name"
}

read_account_keychain() {
  local name="$1"
  validate_vdm_account_name "$name" >/dev/null || return 1
  security find-generic-password -s "${VDM_ACCOUNT_PREFIX}${name}" -a "$KEYCHAIN_ACCOUNT" -w 2>/dev/null
}

write_account_keychain() {
  local name="$1"
  local creds="$2"
  validate_vdm_account_name "$name" >/dev/null || return 1
  security add-generic-password -U \
    -s "${VDM_ACCOUNT_PREFIX}${name}" -a "$KEYCHAIN_ACCOUNT" \
    -w "$creds" >/dev/null 2>&1
}

delete_account_keychain() {
  local name="$1"
  validate_vdm_account_name "$name" >/dev/null || return 1
  security delete-generic-password \
    -s "${VDM_ACCOUNT_PREFIX}${name}" -a "$KEYCHAIN_ACCOUNT" >/dev/null 2>&1 || true
}

# Enumerate all vdm-account-* entries from the user's login keychain.
# Output: one account name per line (without the prefix), sorted+deduped.
list_vdm_account_keychain_entries() {
  security dump-keychain 2>/dev/null \
    | grep -E '"svce"<blob>="vdm-account-' \
    | sed -E 's/.*"svce"<blob>="vdm-account-([^"]+)".*/\1/' \
    | grep -E '^[a-zA-Z0-9._@-]+$' \
    | sort -u
}

# Idempotent migration of legacy accounts/*.json → keychain entries.
# Strategy: write keychain entry FIRST, only delete the file on success.
# Leaves *.label files in place (no secrets, used for display).
migrate_accounts_to_keychain() {
  [[ -d "$ACCOUNTS_DIR" ]] || return 0
  shopt -s nullglob
  local file name creds
  for file in "$ACCOUNTS_DIR"/*.json; do
    name="$(basename "$file" .json)"
    if ! validate_vdm_account_name "$name" >/dev/null; then continue; fi
    # Already migrated? Drop the file and move on.
    if read_account_keychain "$name" >/dev/null 2>&1; then
      rm -f -- "$file"
      continue
    fi
    creds="$(cat "$file" 2>/dev/null)"
    if [[ -z "$creds" ]]; then continue; fi
    if write_account_keychain "$name" "$creds"; then
      rm -f -- "$file"
    fi
  done
  shopt -u nullglob
}

# Read fingerprint of an account stored in the keychain.
get_account_fingerprint() {
  local name="$1"
  local creds
  creds=$(read_account_keychain "$name") || return 1
  echo "$creds" | python3 -c '
import sys, json, hashlib
try:
    d = json.load(sys.stdin)
    token = d.get("claudeAiOauth", {}).get("accessToken", "")
    print(hashlib.sha256(token.encode()).hexdigest()[:16])
except Exception:
    pass
' 2>/dev/null
}

# Compact info string (sub|tier|expires) for an account stored in the
# keychain. Format matches the listing UI: <subscriptionType>|<tier>|<expires>.
get_account_info() {
  local name="$1"
  local creds
  creds=$(read_account_keychain "$name") || return 1
  echo "$creds" | python3 -c '
import sys, json, datetime
try:
    d = json.load(sys.stdin)
    oauth = d.get("claudeAiOauth", {})
    sub = oauth.get("subscriptionType", "unknown")
    tier = oauth.get("rateLimitTier", "unknown")
    expires = oauth.get("expiresAt", 0)
    exp_str = datetime.datetime.fromtimestamp(expires/1000).strftime("%Y-%m-%d %H:%M") if expires else "unknown"
    tier_short = tier.split("_")[-1] if "_" in tier else tier
    print(f"{sub}|{tier_short}|{exp_str}")
except Exception:
    pass
' 2>/dev/null
}

get_active_fingerprint() {
  local creds
  creds=$(read_keychain 2>/dev/null) || return 1
  echo "$creds" | python3 -c "
import sys, json, hashlib
d = json.load(sys.stdin)
token = d.get('claudeAiOauth', {}).get('accessToken', '')
print(hashlib.sha256(token.encode()).hexdigest()[:16])
" 2>/dev/null
}

fetch_account_email() {
  local token="$1"
  local org_name
  # Single-quoted python source. The API response is read from stdin; no
  # bash variable is interpolated into the python literal, so a malicious
  # `organization_name` value cannot escape the JSON loader.
  org_name=$(curl -s \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    -H "User-Agent: claude-code/vdm" \
    "https://api.anthropic.com/api/oauth/claude_cli/roles" 2>/dev/null \
    | python3 -c '
import sys, json, re
try:
    d = json.load(sys.stdin)
    name = d.get("organization_name", "")
    # Extract email from "user@email.com'"'"'s Organization"
    match = re.match(r"(.+?)(?:'"'"'s Organization| Organization)$", name)
    if match:
        print(match.group(1))
    else:
        print(name)
except Exception:
    pass
' 2>/dev/null)
  echo "$org_name"
}

format_sub_type() {
  case "$1" in
    max) echo -e "${BOLD}${CYAN}MAX${NC}" ;;
    pro) echo -e "${BOLD}${BLUE}PRO${NC}" ;;
    free) echo -e "${DIM}FREE${NC}" ;;
    *) echo -e "${DIM}$1${NC}" ;;
  esac
}

# ─────────────────────────────────────────────────────────
# Activity log (shared with dashboard)
# ─────────────────────────────────────────────────────────

log_activity() {
  local type="$1"
  shift
  # Build JSON entry: { "ts": <epoch_ms>, "type": "<type>", ...extra }
  # Single-quoted python source. The log-file path and the type string are
  # passed as the first two positional args (via `--`). Extra key=value
  # pairs follow. Previously `$ACTIVITY_LOG_FILE` and `$type` were
  # interpolated into a double-quoted python source string — a path or
  # type name containing `'`, `$(…)`, or `\n` could escape the literal.
  python3 -c '
import json, time, sys

log_file = sys.argv[1]
type_name = sys.argv[2]
entry = {"ts": int(time.time() * 1000), "type": type_name}

# Parse extra key=value args
for arg in sys.argv[3:]:
    if "=" in arg:
        k, v = arg.split("=", 1)
        entry[k] = v

# Load existing log
log = []
try:
    with open(log_file) as f:
        log = json.load(f)
except Exception:
    pass

log.insert(0, entry)
log = log[:200]  # max 200 entries

with open(log_file, "w") as f:
    json.dump(log, f, indent=2)
' "$ACTIVITY_LOG_FILE" "$type" "$@" 2>/dev/null || true
}

# ─────────────────────────────────────────────────────────
# Config helpers
# ─────────────────────────────────────────────────────────

read_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    cat "$CONFIG_FILE"
  else
    echo '{"autoSwitch":true,"proxyEnabled":true,"rotationStrategy":"sticky","rotationIntervalMin":60}'
  fi
}

write_config() {
  echo "$1" > "$CONFIG_FILE"
}

get_config_value() {
  local key="$1"
  # Pass `$key` via argv so a key containing `'` cannot break the python
  # string literal. `python -c` does NOT honour `--` as a separator
  # (it ends up in sys.argv[1]), so we omit it everywhere below.
  read_config | python3 -c '
import sys, json
print(json.load(sys.stdin).get(sys.argv[1], ""))
' "$key" 2>/dev/null
}

set_config_value() {
  local key="$1"
  local value="$2"
  # `$value` for booleans is the literal text "True" or "False" (validated
  # by cmd_config). We pass it as a string and convert it inside python so
  # `$value` can never be interpolated as raw python code.
  # Atomic write: tmp + os.replace so a SIGKILL/full-disk between
  # truncate and the final byte never leaves a corrupt config.json.
  # We DO NOT swallow stderr — a write failure (read-only FS, no
  # space, permissions) must reach the user, not silently drop their
  # setting change.
  python3 -c '
import json, os, sys
config_file = sys.argv[1]
key = sys.argv[2]
raw = sys.argv[3]
try:
    with open(config_file) as f:
        cfg = json.load(f)
except Exception:
    cfg = {"autoSwitch": True, "proxyEnabled": True}
cfg[key] = (raw == "True")
tmp = config_file + ".tmp"
with open(tmp, "w") as f:
    json.dump(cfg, f, indent=2)
os.replace(tmp, config_file)
' "$CONFIG_FILE" "$key" "$value"
}

get_config_string() {
  local key="$1"
  read_config | python3 -c '
import sys, json
print(json.load(sys.stdin).get(sys.argv[1], ""))
' "$key" 2>/dev/null
}

set_config_string() {
  local key="$1"
  local value="$2"
  # Atomic + surfaced errors — see set_config_value for the rationale.
  python3 -c '
import json, os, sys
config_file = sys.argv[1]
key = sys.argv[2]
value = sys.argv[3]
try:
    with open(config_file) as f:
        cfg = json.load(f)
except Exception:
    cfg = {}
cfg[key] = value
tmp = config_file + ".tmp"
with open(tmp, "w") as f:
    json.dump(cfg, f, indent=2)
os.replace(tmp, config_file)
' "$CONFIG_FILE" "$key" "$value"
}

set_config_number() {
  local key="$1"
  local value="$2"
  # Atomic + surfaced errors — see set_config_value.
  python3 -c '
import json, os, sys
config_file = sys.argv[1]
key = sys.argv[2]
raw = sys.argv[3]
try:
    with open(config_file) as f:
        cfg = json.load(f)
except Exception:
    cfg = {}
# Reject anything that is not a finite int — `$value` is validated by the
# caller (cmd_config restricts it to a fixed allow-list) but we re-validate
# here so a future caller cannot smuggle in a non-numeric literal.
cfg[key] = int(raw)
tmp = config_file + ".tmp"
with open(tmp, "w") as f:
    json.dump(cfg, f, indent=2)
os.replace(tmp, config_file)
' "$CONFIG_FILE" "$key" "$value"
}

# ─────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────

cmd_add() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo -e "${RED}Usage: vdm add <name>${NC}"
    echo "  Saves the currently logged-in credentials as a named profile."
    echo "  Example: vdm add work-account"
    return 1
  fi

  # Sanitize name through the strict whitelist (rejects path traversal,
  # glob metacharacters, command-substitution chars, leading dashes).
  if ! name=$(sanitize_profile_name "$name"); then
    echo -e "${RED}Invalid profile name. Use alphanumerics, '_', '.', or '-'.${NC}"
    return 1
  fi
  if ! validate_vdm_account_name "$name" >/dev/null; then
    echo -e "${RED}Reserved name. Pick another.${NC}"
    return 1
  fi

  local creds
  creds=$(read_keychain) || {
    echo -e "${RED}No credentials found in Keychain. Run 'claude login' first.${NC}"
    return 1
  }

  if ! write_account_keychain "$name" "$creds"; then
    echo -e "${RED}Failed to write account to Keychain.${NC}"
    return 1
  fi

  local info
  info=$(get_account_info "$name")
  local sub_type=$(echo "$info" | cut -d'|' -f1)
  local tier=$(echo "$info" | cut -d'|' -f2)
  local expires=$(echo "$info" | cut -d'|' -f3)

  # Auto-fetch email from API
  local token
  token=$(echo "$creds" | python3 -c '
import sys, json
print(json.load(sys.stdin)["claudeAiOauth"]["accessToken"])
' 2>/dev/null)
  local email=""
  if [[ -n "$token" ]]; then
    email=$(fetch_account_email "$token")
  fi
  if [[ -n "$email" ]]; then
    # Label files carry no secret material — just an email/display name —
    # so they remain plain files. `$name` was validated above.
    echo "$email" > "$ACCOUNTS_DIR/${name}.label"
  fi

  echo -e "${GREEN}✓${NC} Saved profile ${BOLD}$name${NC}"
  if [[ -n "$email" ]]; then
    echo -e "  Email: ${CYAN}$email${NC}"
  fi
  echo -e "  Plan: $(format_sub_type "$sub_type")  Tier: ${tier}"
  echo -e "  Token expires: ${DIM}$expires${NC}"

  log_activity "account-discovered" "name=$name" "label=${email:-$name}"
}

cmd_label() {
  local name="${1:-}"
  local label="${2:-}"
  if [[ -z "$name" || -z "$label" ]]; then
    echo -e "${RED}Usage: vdm label <name> <label>${NC}"
    echo "  Gives a profile a human-readable label (e.g. email or description)."
    echo "  Example: vdm label work-account john@company.com"
    return 1
  fi

  if ! name=$(sanitize_profile_name "$name"); then
    echo -e "${RED}Invalid profile name. Use alphanumerics, '_', '.', or '-'.${NC}"
    return 1
  fi
  if ! read_account_keychain "$name" >/dev/null 2>&1; then
    echo -e "${RED}Profile '$name' not found.${NC}"
    return 1
  fi

  echo "$label" > "$ACCOUNTS_DIR/${name}.label"
  echo -e "${GREEN}✓${NC} Labeled ${BOLD}$name${NC} as ${CYAN}$label${NC}"

  log_activity "account-renamed" "name=$name" "label=$label"
}

cmd_list() {
  local active_fp
  active_fp=$(get_active_fingerprint 2>/dev/null) || active_fp=""

  # Enumerate saved profiles from the keychain (vdm-account-* services).
  local names=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && names+=("$line")
  done < <(list_vdm_account_keychain_entries)

  if [[ ${#names[@]} -eq 0 ]]; then
    echo -e "${YELLOW}No saved profiles. Use 'vdm add <name>' to save the current account.${NC}"
    return 0
  fi

  echo ""
  echo -e "${BOLD}  Van Damme-o-Matic Accounts${NC}"
  echo -e "  ─────────────────────────────────────────────"

  local name fp info sub_type tier expires label_file label
  for name in "${names[@]}"; do
    fp=$(get_account_fingerprint "$name" 2>/dev/null)
    info=$(get_account_info "$name" 2>/dev/null)
    sub_type=$(echo "$info" | cut -d'|' -f1)
    tier=$(echo "$info" | cut -d'|' -f2)
    expires=$(echo "$info" | cut -d'|' -f3)
    label_file="$ACCOUNTS_DIR/${name}.label"
    label=""
    [[ -f "$label_file" ]] && label=$(cat "$label_file")

    if [[ "$fp" == "$active_fp" ]]; then
      echo -e "  ${GREEN}▸ ${BOLD}$name${NC}  $(format_sub_type "$sub_type")  ${GREEN}← active${NC}"
    else
      echo -e "    ${BOLD}$name${NC}  $(format_sub_type "$sub_type")"
    fi
    if [[ -n "$label" ]]; then
      echo -e "      ${DIM}$label${NC}"
    fi
    echo -e "      ${DIM}tier: $tier  expires: $expires${NC}"
  done

  echo ""
}

cmd_switch() {
  local auto=false
  local name=""

  # Parse args: support --auto plus an optional positional name.
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auto) auto=true; shift ;;
      --) shift; name="${1:-}"; shift 2>/dev/null || true; break ;;
      -*) echo -e "${RED}Unknown flag: $1${NC}"; return 1 ;;
      *)  name="$1"; shift ;;
    esac
  done

  # Enumerate saved profiles from the keychain.
  local names=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && names+=("$line")
  done < <(list_vdm_account_keychain_entries)

  if [[ ${#names[@]} -eq 0 ]]; then
    echo -e "${YELLOW}No saved profiles. Use 'vdm add <name>' to save the current account.${NC}"
    return 1
  fi

  local active_fp
  active_fp=$(get_active_fingerprint 2>/dev/null) || active_fp=""

  # --auto: skip the interactive menu and ask the dashboard to pick the
  # next available account using the current rotation strategy. Falls back
  # to a local round-robin pick if the dashboard is unreachable.
  if [[ "$auto" == "true" ]]; then
    if [[ -n "$name" ]]; then
      echo -e "${RED}--auto cannot be combined with an explicit name${NC}"
      return 1
    fi
    local resp
    resp=$(curl -fsS --max-time 5 -X POST \
      -H 'Content-Type: application/json' \
      -d '{"auto":true}' \
      "http://localhost:${CSW_PORT:-3333}/api/switch?auto=true" 2>/dev/null) || resp=""
    if [[ -n "$resp" ]]; then
      local picked
      picked=$(echo "$resp" | python3 -c '
import sys, json
try:
  d = json.load(sys.stdin)
  if d.get("ok"):
    print(d.get("switched", ""))
except Exception:
  pass
' 2>/dev/null)
      if [[ -n "$picked" ]]; then
        local label=""
        [[ -f "$ACCOUNTS_DIR/${picked}.label" ]] && label=$(cat "$ACCOUNTS_DIR/${picked}.label")
        echo -e "${GREEN}✓${NC} Switched to ${BOLD}$picked${NC}${label:+ ${DIM}($label)${NC}}"
        return 0
      fi
    fi
    # Fallback: local round-robin among non-active accounts.
    local pname pfp
    for pname in "${names[@]}"; do
      pfp=$(get_account_fingerprint "$pname" 2>/dev/null)
      if [[ -n "$pfp" && "$pfp" != "$active_fp" ]]; then
        name="$pname"
        break
      fi
    done
    if [[ -z "$name" ]]; then
      echo -e "${RED}No alternative account available.${NC}"
      return 1
    fi
  fi

  if [[ -z "$name" ]]; then
    # Interactive mode: show numbered list
    echo ""
    echo -e "${BOLD}  Select account:${NC}"
    echo ""

    local i=1
    local pname fp info sub_type label_file label
    for pname in "${names[@]}"; do
      fp=$(get_account_fingerprint "$pname" 2>/dev/null)
      info=$(get_account_info "$pname" 2>/dev/null)
      sub_type=$(echo "$info" | cut -d'|' -f1)
      label_file="$ACCOUNTS_DIR/${pname}.label"
      label=""
      [[ -f "$label_file" ]] && label=" ${DIM}($( cat "$label_file"))${NC}"

      if [[ "$fp" == "$active_fp" ]]; then
        echo -e "  ${GREEN}$i)${NC} ${BOLD}$pname${NC}  $(format_sub_type "$sub_type")${label}  ${GREEN}← active${NC}"
      else
        echo -e "  $i) ${BOLD}$pname${NC}  $(format_sub_type "$sub_type")${label}"
      fi
      ((i++))
    done

    echo ""
    read -rp "  Enter number (or q to cancel): " choice

    if [[ "$choice" == "q" || -z "$choice" ]]; then
      echo "  Cancelled."
      return 0
    fi

    if [[ "$choice" -ge 1 && "$choice" -le "${#names[@]}" ]] 2>/dev/null; then
      name="${names[$((choice-1))]}"
    else
      echo -e "  ${RED}Invalid choice.${NC}"
      return 1
    fi
  fi

  if ! name=$(sanitize_profile_name "$name"); then
    echo -e "${RED}Invalid profile name. Use alphanumerics, '_', '.', or '-'.${NC}"
    return 1
  fi

  local creds
  if ! creds=$(read_account_keychain "$name"); then
    echo -e "${RED}Profile '$name' not found.${NC}"
    echo "Available profiles:"
    local _profile
    for _profile in "${names[@]}"; do
      echo "  $_profile"
    done
    return 1
  fi

  # Check if already active
  local target_fp=$(get_account_fingerprint "$name" 2>/dev/null)
  if [[ "$active_fp" == "$target_fp" ]]; then
    echo -e "${YELLOW}Already on profile '$name'.${NC}"
    return 0
  fi

  write_keychain "$creds"

  local info=$(get_account_info "$name" 2>/dev/null)
  local sub_type=$(echo "$info" | cut -d'|' -f1)
  local label_file="$ACCOUNTS_DIR/${name}.label"
  local label=""
  [[ -f "$label_file" ]] && label=$(cat "$label_file")

  echo -e "${GREEN}✓${NC} Switched to ${BOLD}$name${NC}  $(format_sub_type "$sub_type")"
  echo -e "${DIM}  All Claude Code sessions will use this account on their next API call.${NC}"

  log_activity "manual-switch" "to=${label:-$name}"
}

cmd_remove() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo -e "${RED}Usage: vdm remove <name>${NC}"
    return 1
  fi

  # `sanitize_profile_name` strips glob meta-characters (`*`, `?`, `[`),
  # so `vdm remove '*'` cannot expand to `rm -f accounts/*.json` and wipe
  # every saved profile. It also blocks `..` traversal so the rm cannot
  # escape `accounts/`.
  if ! name=$(sanitize_profile_name "$name"); then
    echo -e "${RED}Invalid profile name. Use alphanumerics, '_', '.', or '-'.${NC}"
    return 1
  fi

  if ! read_account_keychain "$name" >/dev/null 2>&1; then
    echo -e "${RED}Profile '$name' not found.${NC}"
    return 1
  fi

  delete_account_keychain "$name"
  rm -f -- "$ACCOUNTS_DIR/${name}.label"
  echo -e "${GREEN}✓${NC} Removed profile ${BOLD}$name${NC}"
}

cmd_status() {
  local creds
  creds=$(read_keychain 2>/dev/null) || {
    echo -e "${RED}No credentials found in Keychain.${NC}"
    return 1
  }

  local active_fp=$(get_active_fingerprint 2>/dev/null)

  # Find matching profile by enumerating vdm-account-* keychain entries
  local active_name="(not saved)"
  local pname pfp
  while IFS= read -r pname; do
    [[ -n "$pname" ]] || continue
    pfp=$(get_account_fingerprint "$pname" 2>/dev/null)
    if [[ "$pfp" == "$active_fp" ]]; then
      active_name="$pname"
      break
    fi
  done < <(list_vdm_account_keychain_entries)

  local info
  info=$(echo "$creds" | python3 -c '
import sys, json, datetime
d = json.load(sys.stdin)
oauth = d.get("claudeAiOauth", {})
sub = oauth.get("subscriptionType", "unknown")
tier = oauth.get("rateLimitTier", "unknown")
expires = oauth.get("expiresAt", 0)
exp_str = datetime.datetime.fromtimestamp(expires/1000).strftime("%Y-%m-%d %H:%M") if expires else "unknown"
scopes = ", ".join(oauth.get("scopes", []))
print(f"{sub}|{tier}|{exp_str}|{scopes}")
')

  local sub_type=$(echo "$info" | cut -d'|' -f1)
  local tier=$(echo "$info" | cut -d'|' -f2)
  local expires=$(echo "$info" | cut -d'|' -f3)
  local scopes=$(echo "$info" | cut -d'|' -f4)

  # Fetch email
  local token
  token=$(echo "$creds" | python3 -c '
import sys, json
print(json.load(sys.stdin)["claudeAiOauth"]["accessToken"])
' 2>/dev/null)
  local email=""
  if [[ -n "$token" ]]; then
    email=$(fetch_account_email "$token")
  fi

  echo ""
  echo -e "${BOLD}  Active Account${NC}"
  echo -e "  ────────────────────────────────"
  if [[ -n "$email" ]]; then
    echo -e "  Email:    ${CYAN}$email${NC}"
  fi
  # Only show profile name if it's a meaningful user-given name (not auto-generated)
  if [[ ! "$active_name" =~ ^auto-[0-9]+$ && "$active_name" != "(not saved)" ]]; then
    echo -e "  Profile:  ${BOLD}$active_name${NC}"
  fi
  echo -e "  Plan:     $(format_sub_type "$sub_type")"
  echo -e "  Tier:     $tier"
  echo -e "  Expires:  $expires"
  echo -e "  Scopes:   ${DIM}$scopes${NC}"

  # Show proxy/auto-switch status
  local proxy_on=$(get_config_value "proxyEnabled")
  local auto_on=$(get_config_value "autoSwitch")
  local strategy=$(get_config_string "rotationStrategy")
  local interval=$(get_config_string "rotationIntervalMin")
  local notifs=$(get_config_value "notifications")
  echo ""
  echo -e "  ${BOLD}Settings${NC}"
  echo -e "  ────────────────────────────────"
  if [[ "$proxy_on" == "True" ]]; then
    echo -e "  Proxy:         ${GREEN}ON${NC}"
  else
    echo -e "  Proxy:         ${DIM}OFF${NC}"
  fi
  if [[ "$auto_on" == "True" ]]; then
    echo -e "  Auto-switch:   ${GREEN}ON${NC}"
  else
    echo -e "  Auto-switch:   ${DIM}OFF${NC}"
  fi
  if [[ "$notifs" == "True" ]]; then
    echo -e "  Notifications: ${GREEN}ON${NC}"
  else
    echo -e "  Notifications: ${DIM}OFF${NC}"
  fi
  echo -e "  Rotation:      ${CYAN}${strategy:-sticky}${NC}"
  if [[ "${strategy:-sticky}" == "round-robin" ]]; then
    echo -e "  Interval:      ${interval:-60} min"
  fi

  # Version
  if [[ -f "$SCRIPT_DIR/.version" ]]; then
    echo -e "  Version:       ${DIM}$(cat "$SCRIPT_DIR/.version")${NC}"
  fi
  echo ""
}

cmd_config() {
  local key="${1:-}"
  local value="${2:-}"

  if [[ -z "$key" ]]; then
    # Show current config
    echo ""
    echo -e "${BOLD}  Settings${NC}"
    echo -e "  ────────────────────────────────"
    local proxy_on=$(get_config_value "proxyEnabled")
    local auto_on=$(get_config_value "autoSwitch")
    local strategy=$(get_config_string "rotationStrategy")
    local interval=$(get_config_string "rotationIntervalMin")
    if [[ "$proxy_on" == "True" ]]; then
      echo -e "  proxyEnabled:       ${GREEN}on${NC}"
    else
      echo -e "  proxyEnabled:       ${DIM}off${NC}"
    fi
    if [[ "$auto_on" == "True" ]]; then
      echo -e "  autoSwitch:         ${GREEN}on${NC}"
    else
      echo -e "  autoSwitch:         ${DIM}off${NC}"
    fi
    local notifs=$(get_config_value "notifications")
    if [[ "$notifs" == "True" ]]; then
      echo -e "  notifications:      ${GREEN}on${NC}"
    else
      echo -e "  notifications:      ${DIM}off${NC}"
    fi
    echo -e "  rotationStrategy:   ${CYAN}${strategy:-sticky}${NC}"
    echo -e "  rotationIntervalMin: ${interval:-60}"
    local serialize=$(get_config_value "serializeRequests")
    if [[ "$serialize" == "True" ]]; then
      echo -e "  serializeRequests:  ${GREEN}on${NC}"
    else
      echo -e "  serializeRequests:  ${DIM}off${NC}"
    fi
    local delay=$(get_config_string "serializeDelayMs")
    echo -e "  serializeDelayMs:   ${delay:-200}"
    local commit_tokens=$(get_config_value "commitTokenUsage")
    if [[ "$commit_tokens" == "True" ]]; then
      echo -e "  commitTokenUsage:   ${GREEN}on${NC}"
    else
      echo -e "  commitTokenUsage:   ${DIM}off${NC}"
    fi
    local session_monitor=$(get_config_value "sessionMonitor")
    if [[ "$session_monitor" == "True" ]]; then
      echo -e "  sessionMonitor:     ${GREEN}on${NC}"
    else
      echo -e "  sessionMonitor:     ${DIM}off${NC}"
    fi
    local per_tool=$(get_config_value "perToolAttribution")
    if [[ "$per_tool" == "True" ]]; then
      echo -e "  perToolAttribution: ${GREEN}on${NC}"
    else
      echo -e "  perToolAttribution: ${DIM}off${NC}"
    fi
    local tu_max_age=$(get_config_string "tokenUsageMaxAgeDays")
    echo -e "  tokenUsageMaxAge:   ${tu_max_age:-90} days"
    local tu_max_entries=$(get_config_string "tokenUsageMaxEntries")
    echo -e "  tokenUsageMaxEntries: ${tu_max_entries:-50000}"
    local act_max=$(get_config_string "activityMaxEntries")
    echo -e "  activityMaxEntries: ${act_max:-500}"
    echo ""
    echo -e "  ${DIM}Usage: vdm config <key> <value>${NC}"
    echo -e "  ${DIM}  vdm config proxy on${NC}"
    echo -e "  ${DIM}  vdm config autoswitch off${NC}"
    echo -e "  ${DIM}  vdm config notifications off${NC}"
    echo -e "  ${DIM}  vdm config rotation sticky|conserve|round-robin|spread|drain-first${NC}"
    echo -e "  ${DIM}  vdm config interval 15|30|60|120${NC}"
    echo -e "  ${DIM}  vdm config serialize on|off${NC}"
    echo -e "  ${DIM}  vdm config serialize-delay 0|100|200|500|1000${NC}"
    echo -e "  ${DIM}  vdm config commit-tokens on|off${NC}"
    echo -e "  ${DIM}  vdm config session-monitor on|off${NC}"
    echo -e "  ${DIM}  vdm config per-tool-attribution on|off${NC}"
    echo -e "  ${DIM}  vdm config token-usage-max-age <1-365 days>${NC}"
    echo -e "  ${DIM}  vdm config token-usage-max-entries <1-500000>${NC}"
    echo -e "  ${DIM}  vdm config activity-max-entries <1-5000>${NC}"
    return 0
  fi

  # Normalize key
  local is_bool=true
  case "$key" in
    proxy|proxyEnabled|proxy-enabled)       key="proxyEnabled" ;;
    autoswitch|autoSwitch|auto-switch)    key="autoSwitch" ;;
    notifications|notifs)                 key="notifications" ;;
    rotation|rotationStrategy|strategy)   key="rotationStrategy"; is_bool=false ;;
    interval|rotationIntervalMin)         key="rotationIntervalMin"; is_bool=false ;;
    serialize|serializeRequests|serialize-requests) key="serializeRequests" ;;
    serialize-delay|serializeDelayMs|serialize-delay-ms) key="serializeDelayMs"; is_bool=false ;;
    commit-tokens|commitTokenUsage|commit-token-usage) key="commitTokenUsage" ;;
    # Phase J/K — keys previously settable only via the dashboard UI.
    session-monitor|sessionMonitor)       key="sessionMonitor" ;;
    per-tool-attribution|perToolAttribution|per-tool) key="perToolAttribution" ;;
    # Retention knobs — let users trade fidelity for disk space.
    token-usage-max-age|tokenUsageMaxAgeDays|token-usage-max-age-days) key="tokenUsageMaxAgeDays"; is_bool=false ;;
    token-usage-max-entries|tokenUsageMaxEntries) key="tokenUsageMaxEntries"; is_bool=false ;;
    activity-max-entries|activityMaxEntries) key="activityMaxEntries"; is_bool=false ;;
    *)
      echo -e "${RED}Unknown setting: $key${NC}"
      echo "  Available: proxy, autoswitch, notifications, rotation, interval, serialize, serialize-delay, commit-tokens, session-monitor, per-tool-attribution, token-usage-max-age, token-usage-max-entries, activity-max-entries"
      return 1
      ;;
  esac

  if [[ -z "$value" ]]; then
    if [[ "$is_bool" == "true" ]]; then
      local current=$(get_config_value "$key")
      echo "$key = $current"
    else
      local current=$(get_config_string "$key")
      echo "$key = $current"
    fi
    return 0
  fi

  if [[ "$is_bool" == "true" ]]; then
    # Boolean setting
    case "$value" in
      on|true|1|yes)   value="True" ;;
      off|false|0|no)  value="False" ;;
      *)
        echo -e "${RED}Invalid value: $value${NC}  (use on/off)"
        return 1
        ;;
    esac
    set_config_value "$key" "$value"
    if [[ "$value" == "True" ]]; then
      echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${GREEN}on${NC}"
    else
      echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${DIM}off${NC}"
    fi
  elif [[ "$key" == "rotationStrategy" ]]; then
    case "$value" in
      sticky|conserve|round-robin|spread|drain-first) ;;
      *)
        echo -e "${RED}Invalid strategy: $value${NC}"
        echo "  Options: sticky, conserve, round-robin, spread, drain-first"
        return 1
        ;;
    esac
    set_config_string "$key" "$value"
    echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${CYAN}$value${NC}"
  elif [[ "$key" == "rotationIntervalMin" ]]; then
    case "$value" in
      15|30|60|120) ;;
      *)
        echo -e "${RED}Invalid interval: $value${NC}  (use 15, 30, 60, or 120)"
        return 1
        ;;
    esac
    set_config_number "$key" "$value"
    echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${CYAN}${value} min${NC}"
  elif [[ "$key" == "serializeDelayMs" ]]; then
    case "$value" in
      0|100|200|500|1000|2000) ;;
      *)
        echo -e "${RED}Invalid delay: $value${NC}  (use 0, 100, 200, 500, 1000, or 2000)"
        return 1
        ;;
    esac
    set_config_number "$key" "$value"
    echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${CYAN}${value} ms${NC}"
  elif [[ "$key" == "tokenUsageMaxAgeDays" ]]; then
    if ! [[ "$value" =~ ^[1-9][0-9]*$ ]] || [[ "$value" -lt 1 ]] || [[ "$value" -gt 365 ]]; then
      echo -e "${RED}Invalid value: $value${NC}  (must be an integer between 1 and 365)"
      return 1
    fi
    set_config_number "$key" "$value"
    echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${CYAN}${value} days${NC}"
  elif [[ "$key" == "tokenUsageMaxEntries" ]]; then
    if ! [[ "$value" =~ ^[1-9][0-9]*$ ]] || [[ "$value" -lt 1 ]] || [[ "$value" -gt 500000 ]]; then
      echo -e "${RED}Invalid value: $value${NC}  (must be an integer between 1 and 500000)"
      return 1
    fi
    set_config_number "$key" "$value"
    echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${CYAN}${value} entries${NC}"
  elif [[ "$key" == "activityMaxEntries" ]]; then
    if ! [[ "$value" =~ ^[1-9][0-9]*$ ]] || [[ "$value" -lt 1 ]] || [[ "$value" -gt 5000 ]]; then
      echo -e "${RED}Invalid value: $value${NC}  (must be an integer between 1 and 5000)"
      return 1
    fi
    set_config_number "$key" "$value"
    echo -e "${GREEN}✓${NC} ${BOLD}$key${NC} = ${CYAN}${value} entries${NC}"
  fi

  log_activity "settings-changed" "$key=$value"
}

# Read a numeric PID from a pidfile; echoes nothing if the file is missing,
# unreadable, or contains anything other than a positive integer (with
# optional surrounding whitespace). Without this guard `kill "$(cat …)"`
# would either error noisily on garbage content or, worse, send SIGTERM to
# an unrelated PID if a tampered pidfile happened to hold a valid integer
# from another user. Callers MUST treat the empty output as "no live PID".
read_pidfile() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local raw
  raw=$(cat "$file" 2>/dev/null) || return 0
  # Trim whitespace; reject anything that is not a positive integer.
  local trimmed="${raw//[[:space:]]/}"
  if [[ "$trimmed" =~ ^[1-9][0-9]*$ ]]; then
    printf '%s' "$trimmed"
  fi
}

cmd_dashboard() {
  local action="${1:-start}"

  case "$action" in
    stop)
      # Try PID file first, then fall back to port-based detection.
      # `read_pidfile` returns "" for a missing/garbage/non-numeric pidfile,
      # so we never pass arbitrary text to `kill` (which would otherwise
      # send SIGTERM to whatever PID a tampered pidfile happens to hold).
      local stopped=false
      local pid
      pid=$(read_pidfile "$DASHBOARD_PID_FILE")
      if [[ -n "$pid" ]]; then
        if kill "$pid" 2>/dev/null; then
          # SIGKILL escalation: if SIGTERM left the process alive (hung
          # event loop, refusing the signal), wait briefly then force-kill.
          # Without this, a wedged dashboard kept the port bound and the
          # next `vdm dashboard start` reported "already running" forever.
          local i=0
          while [[ $i -lt 20 ]] && kill -0 "$pid" 2>/dev/null; do
            sleep 0.1
            i=$((i + 1))
          done
          if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null || true
          fi
          stopped=true
        fi
      fi
      rm -f "$DASHBOARD_PID_FILE"
      if [[ "$stopped" != "true" ]]; then
        # Find by port
        local port_pid
        port_pid=$(lsof -iTCP:"$DASHBOARD_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1) || true
        if [[ -n "$port_pid" && "$port_pid" =~ ^[1-9][0-9]*$ ]]; then
          if kill "$port_pid" 2>/dev/null; then
            local j=0
            while [[ $j -lt 20 ]] && kill -0 "$port_pid" 2>/dev/null; do
              sleep 0.1
              j=$((j + 1))
            done
            if kill -0 "$port_pid" 2>/dev/null; then
              kill -9 "$port_pid" 2>/dev/null || true
            fi
            stopped=true
          fi
        fi
      fi
      if [[ "$stopped" == "true" ]]; then
        echo -e "${GREEN}✓${NC} Dashboard stopped."
      else
        echo -e "${YELLOW}Dashboard was not running.${NC}"
      fi
      ;;
    start|"")
      # Check if already running (by PID file or port). Stale or tampered
      # pidfiles fail the integer check and are removed below so the start
      # path can proceed.
      local pid
      pid=$(read_pidfile "$DASHBOARD_PID_FILE")
      if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        echo -e "${YELLOW}Dashboard already running at http://localhost:$DASHBOARD_PORT${NC}"
        echo -e "${DIM}Use 'vdm dashboard stop' to stop it.${NC}"
        return 0
      fi
      # Stale pidfile (or non-numeric content): clean it up.
      [[ -f "$DASHBOARD_PID_FILE" ]] && rm -f "$DASHBOARD_PID_FILE"
      # Also check by port
      if lsof -iTCP:"$DASHBOARD_PORT" -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo -e "${YELLOW}Dashboard already running at http://localhost:$DASHBOARD_PORT${NC}"
        echo -e "${DIM}Use 'vdm dashboard stop' to stop it.${NC}"
        return 0
      fi

      echo -e "${BLUE}Starting dashboard on http://localhost:$DASHBOARD_PORT${NC}"
      node "$SCRIPT_DIR/dashboard.mjs" &
      local new_pid=$!
      echo "$new_pid" > "$DASHBOARD_PID_FILE"

      # Wait a moment then open
      sleep 0.5
      if kill -0 "$new_pid" 2>/dev/null; then
        echo -e "${GREEN}✓${NC} Dashboard running (PID $new_pid)"
        echo -e "  Dashboard: ${CYAN}http://localhost:$DASHBOARD_PORT${NC}"
        echo -e "  API Proxy: ${CYAN}http://localhost:$PROXY_PORT${NC}"
        open "http://localhost:$DASHBOARD_PORT" 2>/dev/null || echo -e "  Open http://localhost:$DASHBOARD_PORT in your browser"
      else
        echo -e "${RED}Dashboard failed to start. Check Node.js is installed.${NC}"
        rm -f "$DASHBOARD_PID_FILE"
        return 1
      fi
      ;;
    *)
      echo -e "${RED}Usage: vdm dashboard [start|stop]${NC}"
      ;;
  esac
}

cmd_upgrade() {
  local REPO_URL="https://github.com/loekj/claude-acct-switcher.git"
  local tmpdir
  tmpdir=$(mktemp -d)
  # Ensure cleanup on any exit from this function
  trap "rm -rf '$tmpdir'" RETURN

  echo ""
  echo -e "${BOLD}  Upgrading Van Damme-o-Matic…${NC}"
  echo ""

  # Fetch latest from remote
  echo -e "  ${DIM}Fetching latest version…${NC}"
  if ! git clone --depth 1 "$REPO_URL" "$tmpdir" 2>/dev/null; then
    echo -e "  ${RED}Failed to fetch from $REPO_URL${NC}"
    return 1
  fi
  # Shallow clone may miss tags — fetch them explicitly
  git -C "$tmpdir" fetch --tags --quiet 2>/dev/null || true

  # Compare versions using the full commit hash as the canonical form.
  # The previous code stored either a tag (`v1.0.0` from `git describe`) or
  # a 7-char short hash, then compared the two literal strings — so an
  # install that had been tagged on disk but later compared against a short
  # hash (or vice versa) reported a false "outdated" and re-downloaded
  # everything on every invocation. By always resolving both sides to the
  # 40-char SHA-1 we get a stable equality comparison; the human-readable
  # tag/short-hash is computed separately for display only.
  local current_full=""
  local current_display=""
  if [[ -f "$SCRIPT_DIR/.version" ]]; then
    current_display=$(cat "$SCRIPT_DIR/.version")
    # `.version` may hold either a tag (`v1.0.0`) or a full/short hash from
    # an older install. Resolve to a full hash if the local clone knows the
    # ref; otherwise leave empty and force the upgrade.
    current_full=$(git -C "$tmpdir" rev-parse "$current_display" 2>/dev/null \
      || git -C "$tmpdir" rev-parse "${current_display}^{commit}" 2>/dev/null \
      || echo "")
  fi
  local latest_full
  latest_full=$(git -C "$tmpdir" rev-parse HEAD 2>/dev/null) || latest_full=""
  local latest_display
  latest_display=$(git -C "$tmpdir" describe --tags --abbrev=0 2>/dev/null \
    || git -C "$tmpdir" rev-parse --short HEAD 2>/dev/null) || latest_display=""

  # Fail-fast: if `git rev-parse HEAD` could not resolve in the freshly
  # cloned tmpdir (network glitch, partial clone, .git corruption between
  # `git clone` and the rev-parse), bail out without touching the install.
  # The previous code happily proceeded with an empty `latest_full`, wrote
  # an empty `.version`, and forced a re-download on every subsequent run
  # (the `current_full == latest_full` guard is a no-op when both are "").
  if [[ -z "$latest_full" ]]; then
    echo -e "  ${RED}Could not resolve latest version from $REPO_URL — aborting.${NC}"
    echo -e "  ${DIM}No files were modified.${NC}"
    return 1
  fi

  if [[ -n "$current_full" && "$current_full" == "$latest_full" ]]; then
    echo -e "  ${GREEN}✓${NC} Already on the latest version (${DIM}${current_display:-$current_full}${NC})"
    return 0
  fi

  # Verify the fetched repo has the files we need
  for f in vdm dashboard.mjs lib.mjs install-hooks.sh lib-install.sh; do
    if [[ ! -f "$tmpdir/$f" ]]; then
      echo -e "  ${RED}Fetched repo is missing $f — aborting.${NC}"
      return 1
    fi
  done

  # Check if dashboard is running (PID file or listening on port). Use the
  # validated `read_pidfile` helper so a tampered/garbage pidfile does not
  # cause `kill -0` to error or send a signal to an unrelated PID.
  local dashboard_was_running=false
  local _dash_pid
  _dash_pid=$(read_pidfile "$DASHBOARD_PID_FILE")
  if [[ -n "$_dash_pid" ]] && kill -0 "$_dash_pid" 2>/dev/null; then
    dashboard_was_running=true
  elif lsof -iTCP:"$DASHBOARD_PORT" -sTCP:LISTEN -t >/dev/null 2>&1; then
    dashboard_was_running=true
  fi

  # Stop dashboard before overwriting files
  if [[ "$dashboard_was_running" == "true" ]]; then
    echo -e "  ${DIM}Stopping dashboard…${NC}"
    cmd_dashboard stop
    # Also kill any process on the port not tracked by PID file (e.g. shell
    # auto-start). lsof always emits a numeric PID, but we re-validate to
    # match the contract used elsewhere in this file.
    local port_pid
    port_pid=$(lsof -iTCP:"$DASHBOARD_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1) || true
    if [[ -n "$port_pid" && "$port_pid" =~ ^[1-9][0-9]*$ ]]; then
      kill "$port_pid" 2>/dev/null || true
    fi
  fi

  # Overwrite only code files — never touch accounts/, config.json,
  # activity-log.json, .label files, or any other user data.
  # Atomic per-file replace: cp into <name>.new on the same FS, then mv -f
  # (rename(2)). A SIGKILL/^C between cp and mv leaves the original intact
  # so a half-finished upgrade never bricks the install. dashboard.mjs is
  # ~225 KB and the cp window is real on slow disks.
  #
  # Signal-safety: if Ctrl-C arrives BETWEEN file replacements (e.g.
  # vdm + dashboard.mjs already swapped, lib.mjs not yet), we'd leave a
  # mismatched-version install. Trap INT/TERM/HUP during the critical
  # block and revert by removing the .new tmps. The mv-renames
  # themselves are atomic, so once a mv has succeeded that file is OK
  # — the trap only handles the case where the tmp exists but the mv
  # hasn't run.
  echo -e "  ${DIM}Updating files…${NC}"
  local _upg_files=("vdm" "dashboard.mjs" "lib.mjs" "install-hooks.sh" "lib-install.sh")
  _upg_cleanup() {
    local f
    for f in "${_upg_files[@]}"; do
      rm -f "$SCRIPT_DIR/${f}.new" 2>/dev/null || true
    done
  }
  trap '_upg_cleanup; echo -e "\n  ${RED}Upgrade interrupted — install is unchanged.${NC}"; exit 130' INT TERM HUP
  for f in "${_upg_files[@]}"; do
    if ! cp "$tmpdir/$f" "$SCRIPT_DIR/${f}.new"; then
      _upg_cleanup
      trap - INT TERM HUP
      echo -e "  ${RED}Failed to stage $f — upgrade aborted, install unchanged.${NC}"
      return 1
    fi
    if ! mv -f "$SCRIPT_DIR/${f}.new" "$SCRIPT_DIR/$f"; then
      _upg_cleanup
      trap - INT TERM HUP
      echo -e "  ${RED}Failed to move $f into place — upgrade aborted.${NC}"
      return 1
    fi
  done
  trap - INT TERM HUP
  chmod +x "$SCRIPT_DIR/vdm"

  # Write version marker — full SHA-1 so future upgrades can compare without
  # ambiguity. Display value remains the tag/short-hash in the user-facing
  # messages below. Atomic write.
  printf '%s' "$latest_full" > "$SCRIPT_DIR/.version.new" \
    && mv -f "$SCRIPT_DIR/.version.new" "$SCRIPT_DIR/.version"

  # Install hooks if not yet present
  if [[ -f "$SCRIPT_DIR/install-hooks.sh" ]]; then
    source "$SCRIPT_DIR/install-hooks.sh"
    install_hooks && echo -e "  ${GREEN}✓${NC} Token tracking hooks installed" || true
  fi

  # Restart dashboard if it was running
  if [[ "$dashboard_was_running" == "true" ]]; then
    echo -e "  ${DIM}Restarting dashboard…${NC}"
    cmd_dashboard start
  fi

  echo ""
  if [[ -n "$current_display" ]]; then
    echo -e "  ${GREEN}✓${NC} Upgraded ${DIM}$current_display${NC} → ${BOLD}$latest_display${NC}"
  else
    echo -e "  ${GREEN}✓${NC} Upgraded to ${BOLD}$latest_display${NC}"
  fi
  echo ""

  log_activity "upgrade" "from=${current_display:-unknown}" "to=$latest_display"
}

cmd_tokens() {
  # Token usage tracking
  local repo=""
  local branch=""
  local days=1
  local per_commit=false

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)     repo="$2"; shift 2 ;;
      --branch)   branch="$2"; shift 2 ;;
      --days)     days="$2"; shift 2 ;;
      --per-commit) per_commit=true; shift ;;
      --help|-h)
        echo ""
        echo -e "${BOLD}  vdm tokens${NC}  - show token usage"
        echo ""
        echo -e "  ${BOLD}USAGE${NC}"
        echo -e "    vdm tokens [--days N] [--repo PATH] [--branch NAME] [--per-commit]"
        echo ""
        echo -e "  ${BOLD}OPTIONS${NC}"
        echo -e "    ${CYAN}--days N${NC}        Window in days (default: 1)"
        echo -e "    ${CYAN}--repo PATH${NC}     Filter to a specific repo (auto-detected from cwd)"
        echo -e "    ${CYAN}--branch NAME${NC}   Filter to a specific branch"
        echo -e "    ${CYAN}--per-commit${NC}    Group tokens by branch, then by commit within each"
        echo -e "                    branch. Active branch renders first. Legacy"
        echo -e "                    entries (recorded before branch tracking)"
        echo -e "                    appear in their own '(legacy)' section."
        echo ""
        return 0
        ;;
      *)          shift ;;
    esac
  done

  # Auto-detect repo from cwd. Match the dashboard's storage key by using
  # `--git-common-dir` (worktree-aware: returns the main repo root) instead
  # of `--show-toplevel` (returns the worktree directory).
  if [[ -z "$repo" ]]; then
    repo=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/\.git/*$||') ||
      repo=$(git rev-parse --show-toplevel 2>/dev/null) || true
  fi

  local since=$(( ($(date +%s) - days * 86400) * 1000 ))

  # Build URL. Pass `$repo` / `$branch` to python via argv (sys.argv[1]) —
  # interpolating them into a single-quoted python source string broke
  # whenever a path contained an apostrophe (`/Users/foo/O'Brien-project`).
  local url="http://localhost:$DASHBOARD_PORT/api/token-usage?since=$since"
  if [[ -n "$repo" ]]; then
    url="${url}&repo=$(python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=''))" "$repo" 2>/dev/null)"
  fi
  if [[ -n "$branch" ]]; then
    url="${url}&branch=$(python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=''))" "$branch" 2>/dev/null)"
  fi

  local usage
  usage=$(curl -s --max-time 5 "$url" 2>/dev/null) || {
    echo -e "${RED}Could not connect to dashboard. Is it running?${NC}"
    return 1
  }

  if [[ "$per_commit" == "true" && -n "$repo" ]]; then
    # Per-commit breakdown, bucketed first by branch and then by commit
    # within that branch. This is the only way to attribute tokens to
    # commits that landed on parallel-worktree branches that were never
    # merged into the main worktree's HEAD — the previous version walked
    # only the main HEAD's git log and silently dropped those commits
    # into "(uncommitted)".
    echo ""
    echo -e "${BOLD}  Token Usage per Commit${NC}"
    echo -e "  ────────────────────────────────────────────"
    if [[ -n "$repo" ]]; then
      echo -e "  ${DIM}Repo: $repo${NC}"
    fi
    echo ""

    # Resolve the active branch in the calling shell's worktree (NOT the
    # main repo path stored in `$repo`) so the section ordering surfaces
    # what the user is currently working on. `--abbrev-ref HEAD` returns
    # `HEAD` when detached — treat that as "no active branch".
    local active_branch
    active_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)
    if [[ "$active_branch" == "HEAD" ]]; then
      active_branch=""
    fi

    # Pipe `$usage` (potentially many MB of JSON) via stdin and pass
    # `$repo` + `$active_branch` via argv. Single-quoted python source so
    # bash performs no expansion inside it — branch names from the JSON
    # entries cannot escape the python literal.
    printf '%s' "$usage" | python3 -c '
import json, sys, subprocess

raw = sys.stdin.read()
try:
    usage = json.loads(raw)
except Exception:
    usage = []
repo = sys.argv[1]
active_branch = sys.argv[2] if len(sys.argv) > 2 else ""

if not repo:
    print("  No repo specified or detected.")
    sys.exit(0)

def git_log(branch_or_head):
    """Return list of {hash, ts, msg} commits oldest-first for the given
    refspec ("HEAD" or a branch name). Empty list on any failure."""
    try:
        out = subprocess.check_output(
            ["git", "-C", repo, "log", "--format=%H %ct %s", "--reverse",
             branch_or_head],
            stderr=subprocess.DEVNULL,
        ).decode().strip().split("\n")
    except Exception:
        return []
    commits = []
    for line in out:
        if not line.strip():
            continue
        parts = line.split(" ", 2)
        if len(parts) >= 3:
            commits.append({
                "hash": parts[0][:7],
                "ts": int(parts[1]) * 1000,
                "msg": parts[2],
            })
    return commits

def branch_exists(branch):
    """True if `branch` resolves to a ref in the repo."""
    if not branch:
        return False
    try:
        subprocess.check_output(
            ["git", "-C", repo, "rev-parse", "--verify", "--quiet", branch],
            stderr=subprocess.DEVNULL,
        )
        return True
    except Exception:
        return False

def render_per_commit(entries, commits):
    """Render the per-commit breakdown for one slice of entries.

    Returns the slice total (so the caller can sum branches into a grand
    total). If `commits` is empty (e.g. the branch was deleted AND we
    cannot read HEAD either), falls back to a single "(uncommitted)" line.
    """
    if not commits:
        bucket_total = sum(e.get("inputTokens", 0) + e.get("outputTokens", 0)
                           for e in entries)
        if bucket_total > 0:
            print(f"  (uncommitted)  {bucket_total:>10,} tok")
        return bucket_total

    # Same bucket strategy as the original (Bug A/B/C fixes preserved):
    #   * pre-history: ts < commits[0].ts
    #   * commit i:    commits[i].ts <= ts < commits[i+1].ts
    #     (last commit i: commits[-1].ts <= ts < commits[-1].ts + 1, so
    #     uncommitted strictly comes after — no double-counting)
    #   * uncommitted: ts > commits[-1].ts
    pre_history = sum(e.get("inputTokens", 0) + e.get("outputTokens", 0)
                      for e in entries if e["ts"] < commits[0]["ts"])

    buckets = []
    last_idx = len(commits) - 1
    for i, c in enumerate(commits):
        start_ts = c["ts"]
        end_ts = commits[-1]["ts"] + 1 if i == last_idx else commits[i + 1]["ts"]
        tokens = sum(e.get("inputTokens", 0) + e.get("outputTokens", 0)
                     for e in entries if start_ts <= e["ts"] < end_ts)
        if tokens > 0:
            buckets.append({
                "hash": c["hash"],
                "tokens": tokens,
                "msg": c["msg"][:60],
            })

    uncommitted = sum(e.get("inputTokens", 0) + e.get("outputTokens", 0)
                      for e in entries if e["ts"] > commits[-1]["ts"])

    if pre_history > 0:
        print(f"  (pre-history)  {pre_history:>10,} tok  before first commit")

    # NOTE: f-strings cannot contain `\"` inside their expression — even in
    # Python 3.14 (PEP 701 lifted nesting restrictions but the lexer still
    # parses backslash inside the expression as a continuation, so
    # `f"{b[\"x\"]}"` is a SyntaxError). The original aggregator had this
    # same bug but `2>/dev/null` on the python invocation silently swallowed
    # the SyntaxError, leaving an empty per-commit table for users. We
    # extract the dict access first, then format — no quote nesting needed.
    for b in buckets:
        bh = b["hash"]
        bt = b["tokens"]
        bm = b["msg"]
        print(f"  {bh}  {bt:>10,} tok  {bm}")

    if uncommitted > 0:
        print(f"  (uncommitted)  {uncommitted:>10,} tok")

    return pre_history + sum(b["tokens"] for b in buckets) + uncommitted

# Group entries by branch. Entries without a `branch` field (legacy data
# written before dashboard.mjs started recording it) collect into a single
# "(legacy)" pseudo-group. Entries whose branch field is the empty string
# or null are also legacy.
groups = {}      # branch_name -> list[entry]
legacy = []
for e in usage:
    br = e.get("branch")
    if br:
        groups.setdefault(br, []).append(e)
    else:
        legacy.append(e)

# Legacy-only fast path: keep the old flat per-commit table for installs
# that still hold pre-branch-tracking history. Behaviour-identical to the
# original aggregator on that data.
if not groups:
    if not legacy:
        print("  No token usage found in this period.")
        sys.exit(0)
    commits = git_log("HEAD")
    total = render_per_commit(legacy, commits)
    if total <= 0:
        print("  No token usage found in this period.")
        sys.exit(0)
    print("")
    print(f"  Total: {total:,} tokens")
    sys.exit(0)

# Cache `git rev-parse --verify` per branch (called once per group, NOT
# once per entry). We also cache the resolved git log so the fallback HEAD
# log is fetched at most once even if many branches were deleted.
log_cache = {}   # cache key (str) -> commits list

def commits_for_branch(branch):
    """Resolve the commit list to bucket against for a given branch.
    If the branch ref still exists, use its log. Otherwise fall back to
    the main HEAD log so deleted branches still attribute work to commits
    that landed on the integration branch."""
    if branch_exists(branch):
        key = f"branch:{branch}"
        if key not in log_cache:
            log_cache[key] = git_log(branch)
        return log_cache[key]
    if "head" not in log_cache:
        log_cache["head"] = git_log("HEAD")
    return log_cache["head"]

# Sort: active branch first (if it exists in groups), then the rest
# alphabetically. Stable, predictable output regardless of dict order.
sorted_branches = sorted(groups.keys())
if active_branch and active_branch in groups:
    sorted_branches.remove(active_branch)
    sorted_branches.insert(0, active_branch)

grand_total = 0
first_section = True
for branch in sorted_branches:
    if not first_section:
        print("")
    first_section = False
    print(f"=== Branch: {branch} ===")
    commits = commits_for_branch(branch)
    grand_total += render_per_commit(groups[branch], commits)

if legacy:
    if not first_section:
        print("")
    print("=== Legacy (pre-branch-tracking) ===")
    grand_total += render_per_commit(legacy, git_log("HEAD"))

if grand_total <= 0:
    print("  No token usage found in this period.")
    sys.exit(0)

print("")
print(f"  Total: {grand_total:,} tokens")
' "$repo" "$active_branch" 2>/dev/null
    echo ""
    return 0
  fi

  # Standard summary view
  echo ""
  echo -e "${BOLD}  Token Usage Summary${NC}"
  echo -e "  ────────────────────────────────────────────"
  if [[ -n "$repo" ]]; then
    echo -e "  ${DIM}Repo: $repo${NC}"
  fi
  if [[ -n "$branch" ]]; then
    echo -e "  ${DIM}Branch: $branch${NC}"
  fi
  echo -e "  ${DIM}Period: last $days day(s)${NC}"
  echo ""

  # Pipe `$usage` (the dashboard's JSON response) into python via stdin
  # instead of interpolating it into a `'''…'''` triple-quoted python
  # literal. The previous form crashed with SyntaxError when the JSON
  # response happened to contain `'''`, and was bound by the OS ARG_MAX
  # ceiling (~256 KB on macOS) when the activity log grew large.
  printf '%s' "$usage" | python3 -c '
import json, sys

raw = sys.stdin.read()
try:
    usage = json.loads(raw)
except Exception:
    usage = []

if not usage:
    print("  No token usage recorded in this period.")
    sys.exit(0)

# Group by model
models = {}
total_in = 0
total_out = 0
for e in usage:
    m = e.get("model", "unknown")
    if m not in models:
        models[m] = {"input": 0, "output": 0}
    models[m]["input"] += e.get("inputTokens", 0)
    models[m]["output"] += e.get("outputTokens", 0)
    total_in += e.get("inputTokens", 0)
    total_out += e.get("outputTokens", 0)

for model, counts in sorted(models.items()):
    total = counts["input"] + counts["output"]
    print(f"  {model}")
    inp = counts["input"]
    out = counts["output"]
    print(f"    Input:  {inp:>10,} tokens")
    print(f"    Output: {out:>10,} tokens")
    print(f"    Total:  {total:>10,} tokens")
    print()

grand = total_in + total_out
print(f"  Grand Total: {grand:,} tokens ({total_in:,} in / {total_out:,} out)")
print(f"  Entries: {len(usage)}")
' 2>/dev/null
  echo ""
}

cmd_logs() {
  local filter="${1:-}"

  # Check if dashboard is running
  if ! curl -s --max-time 2 "http://localhost:$DASHBOARD_PORT/health" >/dev/null 2>&1; then
    echo -e "${RED}Dashboard is not running. Start it with: vdm dashboard${NC}"
    return 1
  fi

  echo -e "${BOLD}  Van Damme-o-Matic — Live Proxy Logs${NC}"
  echo -e "  ─────────────────────────────────────────────"
  if [[ -n "$filter" ]]; then
    echo -e "  ${DIM}Filter: $filter${NC}"
  fi
  echo -e "  ${DIM}Press Ctrl-C to stop${NC}"
  echo ""

  # Stream SSE logs, parse the JSON data lines, colorize by tag.
  # Single-quoted python source — bash does no expansion inside it. The
  # JSON payload is read from stdin. We emit `color + line + reset` via
  # plain string concatenation rather than an f-string `f'{color}{line}{reset}'`
  # so the printer cannot accidentally interpret a `{...}` substring inside
  # `line` as a format-spec on Python builds where future PEP changes
  # alter f-string parsing.
  curl -s -N "http://localhost:$DASHBOARD_PORT/api/logs/stream" 2>/dev/null | while IFS= read -r line; do
    # SSE format: "data: {...}"
    if [[ "$line" == data:* ]]; then
      local json_payload="${line#data: }"
      local log_line
      log_line=$(echo "$json_payload" | python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
    tag = d.get("tag", "")
    line = d.get("line", d.get("msg", ""))
    colors = {
        "error":     "\033[0;31m",
        "warn":      "\033[1;33m",
        "switch":    "\033[0;36m",
        "refresh":   "\033[0;34m",
        "proactive": "\033[0;35m",
        "info":      "\033[0m",
        "system":    "\033[0;32m",
    }
    color = colors.get(tag, "\033[2m")
    reset = "\033[0m"
    print(color + line + reset)
except Exception:
    pass
' 2>/dev/null)
      if [[ -n "$log_line" ]]; then
        # Filter is a fixed substring, not a regex. Use `-F` so metachars
        # like `.`, `*`, `[`, `\` in the user's filter are matched literally
        # (e.g. `vdm logs '['` previously failed with "Unmatched [" from
        # BRE parsing). `--` guards against filter starting with `-`.
        if [[ -z "$filter" ]] || echo "$log_line" | grep -qiF -- "$filter" 2>/dev/null; then
          echo -e "  $log_line"
        fi
      fi
    fi
  done
}

